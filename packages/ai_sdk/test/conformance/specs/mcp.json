{
  "version": "6.0",
  "feature": "MCPClient",
  "description": "V6 contract for MCPClient: initialize handshake, tool discovery, tool invocation, and error handling",
  "cases": [
    {
      "id": "initialize-sends-protocol-version",
      "description": "initialize() sends the MCP protocol version and capabilities",
      "method": "initialize",
      "expectedRequest": {
        "method": "initialize",
        "params.protocolVersion": "2024-11-05",
        "params.capabilities.tools": {}
      },
      "serverResponse": {
        "result": {
          "protocolVersion": "2024-11-05",
          "capabilities": { "tools": {} },
          "serverInfo": { "name": "test-server", "version": "1.0.0" }
        }
      }
    },
    {
      "id": "initialize-idempotent",
      "description": "initialize() is a no-op if already initialized (does not send a second request)",
      "expected": {
        "initializeCallCount": 1
      }
    },
    {
      "id": "tools-returns-toolset",
      "description": "tools() returns a ToolSet with correct tool names and schemas",
      "method": "tools/list",
      "serverResponse": {
        "result": {
          "tools": [
            {
              "name": "get_weather",
              "description": "Get current weather for a city",
              "inputSchema": {
                "type": "object",
                "properties": { "city": { "type": "string" } }
              }
            },
            {
              "name": "calculate",
              "description": "Perform arithmetic",
              "inputSchema": {
                "type": "object",
                "properties": {
                  "expression": { "type": "string" }
                }
              }
            }
          ]
        }
      },
      "expected": {
        "toolCount": 2,
        "toolNames": ["get_weather", "calculate"]
      }
    },
    {
      "id": "call-tool-returns-text",
      "description": "callTool() returns text content from an MCP tool response",
      "method": "tools/call",
      "toolName": "get_weather",
      "toolInput": { "city": "Paris" },
      "serverResponse": {
        "result": {
          "content": [{ "type": "text", "text": "Sunny, 18°C" }],
          "isError": false
        }
      },
      "expected": {
        "result": "Sunny, 18°C"
      }
    },
    {
      "id": "call-tool-throws-on-error",
      "description": "callTool() throws MCPException when isError is true",
      "method": "tools/call",
      "toolName": "get_weather",
      "toolInput": { "city": "INVALID" },
      "serverResponse": {
        "result": {
          "content": [{ "type": "text", "text": "Unknown city" }],
          "isError": true
        }
      },
      "expected": {
        "throws": "MCPException",
        "messageContains": "Unknown city"
      }
    },
    {
      "id": "initialize-error-throws",
      "description": "initialize() throws MCPException when server returns a JSON-RPC error",
      "serverResponse": {
        "error": { "code": -32600, "message": "Invalid Request" }
      },
      "expected": {
        "throws": "MCPException",
        "messageContains": "Initialize failed"
      }
    },
    {
      "id": "mcp-exception-has-message",
      "description": "MCPException exposes a message field and toString includes it",
      "expected": {
        "MCPException.message": "non-null string",
        "MCPException.toString": "contains MCPException"
      }
    },
    {
      "id": "stdio-transport-exists",
      "description": "StdioMCPTransport is exported with command and args constructor parameters",
      "expected": {
        "constructor": "StdioMCPTransport(command: String, args: List<String>)"
      }
    },
    {
      "id": "sse-transport-exists",
      "description": "SseClientTransport is exported with url constructor parameter",
      "expected": {
        "constructor": "SseClientTransport(url: Uri)"
      }
    }
  ]
}
