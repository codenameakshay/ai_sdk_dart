{
  "version": "6.0",
  "feature": "Anthropic provider wire format",
  "description": "Wire-format contracts for the Anthropic provider: request shape, extended thinking, streaming",
  "cases": [
    {
      "id": "generate-text-request-shape",
      "description": "generateText sends a POST to /v1/messages with model, messages, max_tokens, and stream:false",
      "method": "POST",
      "path": "/v1/messages",
      "expectedRequestFields": {
        "model": "claude-sonnet-4-5",
        "stream": false,
        "messages[0].role": "user",
        "max_tokens": "non-zero integer"
      },
      "mockResponse": {
        "id": "msg_1",
        "model": "claude-sonnet-4-5",
        "stop_reason": "end_turn",
        "content": [{ "type": "text", "text": "hello" }],
        "usage": { "input_tokens": 5, "output_tokens": 3 }
      },
      "expected": {
        "text": "hello",
        "usage.inputTokens": 5,
        "usage.outputTokens": 3
      }
    },
    {
      "id": "stream-text-request-shape",
      "description": "streamText sends stream:true",
      "method": "POST",
      "path": "/v1/messages",
      "expectedRequestFields": {
        "stream": true
      },
      "mockStreamEvents": [
        { "type": "message_start", "message": { "id": "msg_2", "model": "claude-sonnet-4-5", "usage": { "input_tokens": 4 } } },
        { "type": "content_block_start", "index": 0, "content_block": { "type": "text" } },
        { "type": "content_block_delta", "index": 0, "delta": { "type": "text_delta", "text": "hello" } },
        { "type": "content_block_stop", "index": 0 },
        { "type": "message_delta", "delta": { "stop_reason": "end_turn" }, "usage": { "output_tokens": 3 } },
        { "type": "message_stop" }
      ],
      "expected": {
        "text": "hello",
        "finishReason": "stop"
      }
    },
    {
      "id": "extended-thinking-content-block",
      "description": "Anthropic thinking content blocks are mapped to ReasoningPart in the result",
      "mockResponse": {
        "id": "msg_3",
        "model": "claude-sonnet-4-5",
        "stop_reason": "end_turn",
        "content": [
          { "type": "thinking", "thinking": "Let me consider this carefully." },
          { "type": "text", "text": "The answer is 42." }
        ]
      },
      "expected": {
        "text": "The answer is 42.",
        "reasoning.length": 1,
        "reasoning[0].text": "Let me consider this carefully.",
        "reasoningText": "Let me consider this carefully."
      }
    },
    {
      "id": "tool-use-content-block",
      "description": "Anthropic tool_use content blocks are mapped to ToolCallPart",
      "mockResponse": {
        "id": "msg_4",
        "model": "claude-sonnet-4-5",
        "stop_reason": "tool_use",
        "content": [
          {
            "type": "tool_use",
            "id": "toolu_01",
            "name": "getWeather",
            "input": { "city": "Paris" }
          }
        ]
      },
      "expected": {
        "toolCalls.length": 1,
        "toolCalls[0].toolName": "getWeather",
        "finishReason": "tool-calls"
      }
    }
  ]
}
