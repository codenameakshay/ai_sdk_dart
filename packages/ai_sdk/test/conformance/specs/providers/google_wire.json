{
  "version": "6.0",
  "feature": "Google provider wire format",
  "description": "Wire-format contracts for the Google Generative AI provider: request shape, streaming, embeddings",
  "cases": [
    {
      "id": "generate-text-request-shape",
      "description": "generateText sends a POST to /:model:generateContent with contents array",
      "method": "POST",
      "pathSuffix": ":generateContent",
      "expectedRequestFields": {
        "contents[0].role": "user",
        "contents[0].parts[0].text": "hi"
      },
      "mockResponse": {
        "candidates": [
          {
            "finishReason": "STOP",
            "content": { "parts": [{ "text": "hello" }] }
          }
        ],
        "usageMetadata": { "promptTokenCount": 5, "candidatesTokenCount": 3 }
      },
      "expected": {
        "text": "hello",
        "usage.inputTokens": 5,
        "usage.outputTokens": 3
      }
    },
    {
      "id": "stream-text-request-shape",
      "description": "streamText sends a POST to /:model:streamGenerateContent",
      "method": "POST",
      "pathSuffix": ":streamGenerateContent",
      "mockStreamEvents": [
        {
          "candidates": [
            {
              "content": { "parts": [{ "text": "hello" }] },
              "finishReason": "STOP"
            }
          ]
        }
      ],
      "expected": {
        "text": "hello",
        "finishReason": "stop"
      }
    },
    {
      "id": "function-call-response",
      "description": "Google functionCall parts are mapped to ToolCallPart",
      "mockResponse": {
        "candidates": [
          {
            "finishReason": "STOP",
            "content": {
              "parts": [
                {
                  "functionCall": {
                    "name": "getWeather",
                    "args": { "city": "Tokyo" }
                  }
                }
              ]
            }
          }
        ]
      },
      "expected": {
        "toolCalls.length": 1,
        "toolCalls[0].toolName": "getWeather"
      }
    },
    {
      "id": "embedding-request-shape",
      "description": "embed() sends a POST to /models/:model:embedContent with content.parts",
      "method": "POST",
      "pathSuffix": ":embedContent",
      "expectedRequestFields": {
        "content.parts[0].text": "hello world"
      },
      "mockResponse": {
        "embedding": {
          "values": [0.1, 0.2, 0.3]
        }
      },
      "expected": {
        "embedding.length": 3,
        "embedding[0]": 0.1
      }
    },
    {
      "id": "finish-reason-mapping",
      "description": "Google STOP maps to LanguageModelV3FinishReason.stop",
      "mockResponse": {
        "candidates": [
          { "finishReason": "STOP", "content": { "parts": [{ "text": "ok" }] } }
        ]
      },
      "expected": {
        "finishReason": "stop"
      }
    }
  ]
}
