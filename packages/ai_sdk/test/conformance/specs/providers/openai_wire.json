{
  "version": "6.0",
  "feature": "OpenAI provider wire format",
  "description": "Wire-format contracts for the OpenAI provider: request shape, response parsing, streaming usage chunks",
  "cases": [
    {
      "id": "generate-text-request-shape",
      "description": "generateText sends a POST to /v1/chat/completions with model, messages, and stream:false",
      "method": "POST",
      "path": "/v1/chat/completions",
      "expectedRequestFields": {
        "model": "gpt-4.1-mini",
        "stream": false,
        "messages[0].role": "user"
      },
      "mockResponse": {
        "id": "chatcmpl-1",
        "model": "gpt-4.1-mini",
        "choices": [
          { "finish_reason": "stop", "message": { "content": "hello" } }
        ],
        "usage": { "prompt_tokens": 5, "completion_tokens": 3, "total_tokens": 8 }
      },
      "expected": {
        "text": "hello",
        "usage.inputTokens": 5,
        "usage.outputTokens": 3
      }
    },
    {
      "id": "stream-text-request-shape",
      "description": "streamText sends stream:true and stream_options.include_usage:true",
      "method": "POST",
      "path": "/v1/chat/completions",
      "expectedRequestFields": {
        "stream": true,
        "stream_options.include_usage": true
      },
      "mockStreamChunks": [
        {
          "id": "chatcmpl-2",
          "choices": [{ "delta": { "content": "hi" }, "finish_reason": null }]
        },
        {
          "id": "chatcmpl-2",
          "choices": [{ "delta": {}, "finish_reason": "stop" }],
          "usage": { "prompt_tokens": 4, "completion_tokens": 2, "total_tokens": 6 }
        }
      ],
      "expected": {
        "text": "hi",
        "usage.inputTokens": 4,
        "usage.outputTokens": 2
      }
    },
    {
      "id": "tool-call-request-shape",
      "description": "Tools are sent in the tools array with type:function and function.parameters",
      "expectedRequestFields": {
        "tools[0].type": "function",
        "tools[0].function.name": "getWeather",
        "tools[0].function.parameters.type": "object"
      }
    },
    {
      "id": "streaming-usage-chunk",
      "description": "Usage data in a streaming response final chunk is captured and exposed via result.usage",
      "mockStreamChunks": [
        {
          "choices": [{ "delta": { "content": "test" }, "finish_reason": null }]
        },
        {
          "choices": [{ "delta": {}, "finish_reason": "stop" }],
          "usage": { "prompt_tokens": 10, "completion_tokens": 5, "total_tokens": 15 }
        }
      ],
      "expected": {
        "usage.inputTokens": 10,
        "usage.outputTokens": 5
      }
    }
  ]
}
