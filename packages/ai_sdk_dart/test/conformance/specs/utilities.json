{
  "version": "6.0",
  "feature": "utilities",
  "description": "V6 contract for generateId, createIdGenerator, and simulateReadableStream",
  "cases": [
    {
      "id": "generate-id-unique",
      "description": "generateId() returns unique strings across consecutive calls",
      "expected": {
        "uniqueIds": true
      }
    },
    {
      "id": "generate-id-default-length",
      "description": "generateId() with no args returns a 7-char nanoid-style string",
      "expected": {
        "length": 7
      }
    },
    {
      "id": "generate-id-custom-size",
      "description": "generateId(size: 16) returns a 16-char string",
      "size": 16,
      "expected": {
        "length": 16
      }
    },
    {
      "id": "create-id-generator",
      "description": "createIdGenerator() returns a function that generates unique IDs",
      "expected": {
        "uniqueIds": true
      }
    },
    {
      "id": "create-id-generator-size",
      "description": "createIdGenerator(size: 12) returns a function producing 12-char IDs",
      "size": 12,
      "expected": {
        "length": 12
      }
    },
    {
      "id": "simulate-readable-stream",
      "description": "simulateReadableStream emits all parts in order",
      "parts": ["text-start", "text-delta", "text-end", "finish"],
      "expected": {
        "emitted.count": 4,
        "order": "preserved"
      }
    },
    {
      "id": "simulate-readable-stream-initial-delay",
      "description": "simulateReadableStream with initialDelayInMs delays only the first chunk",
      "initialDelayInMs": 20,
      "expected": {
        "firstChunkDelayed": true
      }
    },
    {
      "id": "simulate-readable-stream-chunk-delay",
      "description": "simulateReadableStream with chunkDelayInMs adds delay between chunks",
      "chunkDelayInMs": 10,
      "expected": {
        "duration >= chunkDelay * (parts.count - 1)": true
      }
    }
  ]
}
